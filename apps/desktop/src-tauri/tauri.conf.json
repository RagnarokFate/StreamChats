{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop",
  "version": "0.1.0",
  "identifier": "com.streamchats.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../overlay-ui",
    "devUrl": "http://localhost:5173/dashboard",
    "beforeBuildCommand": "npm run build --prefix ../overlay-ui",
    "frontendDist": "../../overlay-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "StreamChats",
        "width": 1200,
        "height": 800,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
