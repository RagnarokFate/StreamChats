{
  "name": "obs-chat-aggregator",
  "version": "1.0.0",
  "description": "OBS Multi-Platform Realtime Chat Aggregation Engine",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev -w @obs-chat/overlay-ui\" \"npm start -w @obs-chat/local-server\"",
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "build:desktop": "npm run build && npm run tauri build -w desktop"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "connectors/*",
    "tools/*"
  ]
}
